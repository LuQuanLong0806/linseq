{
  "name": "linesequence-server",
  "version": "1.0.0",
  "description": "LineSequence Backend Server - Task Automation & Intranet Sync",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/bundle.mjs --format=esm --external:better-sqlite3 --external:puppeteer",
    "lint": "eslint src --ext .ts",
    "test": "vitest"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "dayjs": "^1.11.10",
    "docx": "^9.7.0",
    "express": "^4.19.2",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "puppeteer": "^22.0.0",
    "uuid": "^9.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.0",
    "pkg": "^5.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
